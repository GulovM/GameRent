    {
      "name": "5. Activation And Credentials",
      "item": [
        {
          "name": "Payment Webhook Success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var secret = pm.collectionVariables.get('paymentWebhookSecret');",
                  "var payload = JSON.stringify({",
                  "  payment_id: pm.collectionVariables.get('paymentId'),",
                  "  rental_id: pm.collectionVariables.get('rentalId'),",
                  "  external_transaction_id: pm.collectionVariables.get('externalTransactionId'),",
                  "  status: 'success'",
                  "});",
                  "pm.variables.set('webhookPayload', payload);",
                  "if (secret) {",
                  "  var sig = CryptoJS.HmacSHA256(payload, secret).toString(CryptoJS.enc.Hex);",
                  "  pm.variables.set('paymentSignature', sig);",
                  "} else {",
                  "  pm.variables.set('paymentSignature', '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Payment-Signature",
                "value": "{{paymentSignature}}",
                "disabled": false
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhookPayload}}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/webhook",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "webhook"
              ]
            },
            "description": "Активирует payment/rental/account. Если paymentWebhookSecret пустой, коллекция всё равно сработает с текущей реализацией сервиса."
          },
          "response": []
        },
        {
          "name": "Replay Same Webhook Idempotently",
