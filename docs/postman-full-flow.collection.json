  "item": [
    {
      "name": "0. Start Here - Full Program Path",
      "description": "Основной сквозной сценарий работы программы. Иди сверху вниз: сначала логин админа и создание игрового аккаунта, потом регистрация арендатора, пополнение баланса, создание аренды, webhook-активация и получение credentials.",
      "item": [
        {
          "name": "Step 1 - Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Админ нужен для добавления нового игрового аккаунта и пополнения баланса арендатору."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.success && json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('adminAccessToken', json.data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Step 2 - Admin Create Game Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"steam_id64\": \"{{steamId64}}\",\n  \"steam_login\": \"{{steamLogin}}\",\n  \"steam_password\": \"{{steamPassword}}\",\n  \"price_per_hour\": {{pricePerHour}},\n  \"security_deposit\": {{securityDeposit}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "accounts"
              ]
            },
            "description": "Создание нового игрового аккаунта. Сервер шифрует Steam-пароль, создаёт запись в accounts и пытается синхронизировать библиотеку."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.success && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('accountId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Step 3 - Admin Sync Account Library",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/accounts/{{accountId}}/sync",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "accounts",
                "{{accountId}}",
                "sync"
              ]
            },
            "description": "Явная синхронизация библиотеки Steam. Полезно, если при создании аккаунта сервер вернул sync_error."
          },
          "response": []
        },
        {
          "name": "Step 4 - Register Rent User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"first_name\": \"{{firstName}}\",\n  \"last_name\": \"{{lastName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Регистрация арендатора. В текущей реализации email сразу считается подтверждённым."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.success && json.data) {",
                  "  if (json.data.access_token) pm.collectionVariables.set('accessToken', json.data.access_token);",
                  "  if (json.data.refresh_token) pm.collectionVariables.set('refreshToken', json.data.refresh_token);",
                  "  if (json.data.user && json.data.user.id) pm.collectionVariables.set('userId', String(json.data.user.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Step 5 - Admin Top Up User Balance",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"balance\": {{topupBalance}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "users",
                "{{userId}}"
              ]
            },
            "description": "Обязательный шаг. Без положительного balance пользователь не сможет создать rental."
          },
          "response": []
        },
        {
          "name": "Step 6 - Check Public Account Availability",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/accounts/{{accountId}}/availability",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                "{{accountId}}",
                "availability"
              ]
            },
            "description": "Публичная проверка, доступен ли игровой аккаунт для аренды."
          },
          "response": []
        },
        {
          "name": "Step 7 - Calculate Rental",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_id\": {{accountId}},\n  \"duration_hours\": {{durationHours}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rentals/calculate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rentals",
                "calculate"
              ]
            },
            "description": "Расчёт цены аренды и депозита перед фактическим созданием rental."
          },
          "response": []
        },
        {
          "name": "Step 8 - Create Rental",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_id\": {{accountId}},\n  \"duration_hours\": {{durationHours}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rentals",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rentals"
              ]
            },
            "description": "Создаёт rental в статусе WaitingPayment. Одновременно создаётся pending payment, а аккаунт резервируется."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.success && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('rentalId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Step 9 - Load Payment For Rental",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ]
            },
            "description": "Находит payment, который был автоматически создан при POST /rentals, и сохраняет paymentId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.success && json.data && Array.isArray(json.data.payments)) {",
                  "  var rentalId = pm.collectionVariables.get('rentalId');",
                  "  var found = json.data.payments.find(function (p) { return String(p.rental_id) === String(rentalId); });",
                  "  if (found && found.id) pm.collectionVariables.set('paymentId', String(found.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Step 10 - Payment Webhook Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Payment-Signature",
                "value": "{{paymentSignature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhookPayload}}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/webhook",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "webhook"
              ]
            },
            "description": "Активирует payment, rental и account. После этого rental становится ACTIVE, а аккаунт уходит в RENTED."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var secret = pm.collectionVariables.get('paymentWebhookSecret');",
                  "var payload = JSON.stringify({",
                  "  payment_id: pm.collectionVariables.get('paymentId'),",
                  "  rental_id: pm.collectionVariables.get('rentalId'),",
                  "  external_transaction_id: pm.collectionVariables.get('externalTransactionId'),",
                  "  status: 'success'",
                  "});",
                  "pm.variables.set('webhookPayload', payload);",
                  "if (secret) {",
                  "  var sig = CryptoJS.HmacSHA256(payload, secret).toString(CryptoJS.enc.Hex);",
                  "  pm.variables.set('paymentSignature', sig);",
                  "} else {",
                  "  pm.variables.set('paymentSignature', '');",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Step 11 - Get Rental Credentials",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/me/rentals/{{rentalId}}/credentials",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "me",
                "rentals",
                "{{rentalId}}",
                "credentials"
              ]
            },
            "description": "Главная точка, через которую пользователь вытаскивает данные доступа к игровому аккаунту. Работает только для owner + ACTIVE rental."
          },
          "response": []
        },
        {
          "name": "Step 12 - Replay Webhook Idempotently",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Payment-Signature",
                "value": "{{paymentSignature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhookPayload}}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/webhook",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "webhook"
              ]
            },
            "description": "Проверка идемпотентности webhook: повтор того же external_transaction_id не должен ломать состояние."
          },
          "response": []
        }
      ]
    },
