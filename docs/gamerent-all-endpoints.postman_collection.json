{
  "info": {
    "_postman_id": "e46b053a-6d49-4d70-96be-7b8b667ee001",
    "name": "GameRent — all API endpoints and end-to-end rental flow",
    "description": "Import this collection into Postman. Run folder 00 End-to-end flow in order. Admin credentials must belong to an existing ADMIN user; paymentWebhookSecret must exactly match PAYMENT_WEBHOOK_SECRET and is intentionally blank by default. Monetary values are integer minor units. There is no HTTP endpoint that ends an ACTIVE rental: the scheduled expiry worker transitions it to EXPIRED; only then use the final admin settlement requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key":"baseUrl","value":"http://localhost:8080/api/v1"},
    {"key":"serviceUrl","value":"http://localhost:8080"},
    {"key":"userEmail","value":"rent.user@example.com"},
    {"key":"userPassword","value":"Testpass123"},
    {"key":"firstName","value":"Ivan"},
    {"key":"lastName","value":"Petrov"},
    {"key":"accessToken","value":""},
    {"key":"refreshToken","value":""},
    {"key":"userId","value":""},
    {"key":"adminEmail","value":"admin@example.com"},
    {"key":"adminPassword","value":"Adminpass123"},
    {"key":"adminAccessToken","value":""},
    {"key":"accountId","value":""},
    {"key":"gameId","value":"1"},
    {"key":"notificationId","value":"1"},
    {"key":"steamId64","value":"76561198000000000"},
    {"key":"steamLogin","value":"steam_test_login"},
    {"key":"steamPassword","value":"steam_test_password"},
    {"key":"pricePerHour","value":"500"},
    {"key":"securityDeposit","value":"1000"},
    {"key":"durationHours","value":"1"},
    {"key":"rentalId","value":""},
    {"key":"paymentId","value":""},
    {"key":"externalTransactionId","value":"tx-{{$timestamp}}"},
    {"key":"paymentWebhookSecret","value":""},
    {"key":"paymentSignature","value":""},
    {"key":"webhookPayload","value":""},
    {"key":"balanceAdjustmentKey","value":"postman-topup-{{$timestamp}}"}
  ],
  "item": [
    {
      "name":"00 End-to-end flow (run in order)",
      "item":[
        {"name":"01 Admin login","event":[{"listen":"test","script":{"exec":["const b=pm.response.json(); pm.test('200',()=>pm.response.to.have.status(200)); pm.collectionVariables.set('adminAccessToken',b.access_token);"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"},"url":"{{baseUrl}}/auth/login"}},
        {"name":"02 Create game account","event":[{"listen":"test","script":{"exec":["const b=pm.response.json(); pm.test('201',()=>pm.response.to.have.status(201)); pm.collectionVariables.set('accountId',b.id);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"steam_id64\": \"{{steamId64}}\",\n  \"steam_login\": \"{{steamLogin}}\",\n  \"steam_password\": \"{{steamPassword}}\",\n  \"price_per_hour\": {{pricePerHour}},\n  \"security_deposit\": {{securityDeposit}}\n}"},"url":"{{baseUrl}}/admin/accounts"}},
        {"name":"03 Register renter","event":[{"listen":"test","script":{"exec":["const b=pm.response.json(); pm.test('201',()=>pm.response.to.have.status(201)); pm.collectionVariables.set('accessToken',b.access_token); pm.collectionVariables.set('refreshToken',b.refresh_token); pm.collectionVariables.set('userId',b.user.id);"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"first_name\": \"{{firstName}}\",\n  \"last_name\": \"{{lastName}}\"\n}"},"url":"{{baseUrl}}/auth/register"}},
        {"name":"04 Credit renter balance","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"amount\": 100000,\n  \"currency\": \"USD\",\n  \"reason_code\": \"MANUAL_TOPUP\",\n  \"comment\": \"Postman end-to-end test balance\",\n  \"idempotency_key\": \"{{balanceAdjustmentKey}}\"\n}"},"url":"{{baseUrl}}/admin/users/{{userId}}/balance-adjustments"}},
        {"name":"05 Calculate rental","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"account_id\":{{accountId}},\"duration_hours\":{{durationHours}}}"},"url":"{{baseUrl}}/rentals/calculate"}},
        {"name":"06 Create rental","event":[{"listen":"test","script":{"exec":["const b=pm.response.json(); pm.test('201',()=>pm.response.to.have.status(201)); pm.collectionVariables.set('rentalId',b.id);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"account_id\":{{accountId}},\"duration_hours\":{{durationHours}}}"},"url":"{{baseUrl}}/rentals"}},
        {"name":"07 Pay rental from balance","event":[{"listen":"test","script":{"exec":["const b=pm.response.json(); pm.test('active rental',()=>pm.expect(b.rental_status).to.eql('ACTIVE')); pm.collectionVariables.set('paymentId',b.payment_id);"]}}],"request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/rentals/{{rentalId}}/pay-with-balance"}},
        {"name":"08 Get active rental credentials","event":[{"listen":"test","script":{"exec":["pm.test('credentials not cached',()=>pm.expect(pm.response.headers.get('Cache-Control')).to.include('no-store')); pm.test('200',()=>pm.response.to.have.status(200));"]}}],"request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/rentals/{{rentalId}}/credentials"}},
        {"name":"09 Check active rental","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/rentals/{{rentalId}}"}},
        {"name":"10 Check final state after expiry","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/rentals/{{rentalId}}"}},
        {"name":"11 Release deposit after EXPIRED/COMPLETED","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/rentals/{{rentalId}}/deposit/release"}}
      ]
    },
    {"name":"01 Health and observability","item":[
      {"name":"Health","request":{"method":"GET","url":"{{serviceUrl}}/healthz"}},
      {"name":"Liveness","request":{"method":"GET","url":"{{serviceUrl}}/health/live"}},
      {"name":"Readiness","request":{"method":"GET","url":"{{serviceUrl}}/health/ready"}},
      {"name":"Prometheus metrics","request":{"method":"GET","url":"{{serviceUrl}}/metrics"}}
    ]},
    {"name":"02 Authentication and profile","item":[
      {"name":"Register","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"email\":\"{{userEmail}}\",\"password\":\"{{userPassword}}\",\"first_name\":\"{{firstName}}\",\"last_name\":\"{{lastName}}\"}"},"url":"{{baseUrl}}/auth/register"}},
      {"name":"Login","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"email\":\"{{userEmail}}\",\"password\":\"{{userPassword}}\"}"},"url":"{{baseUrl}}/auth/login"}},
      {"name":"Refresh token","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"refresh_token\":\"{{refreshToken}}\"}"},"url":"{{baseUrl}}/auth/refresh"}},
      {"name":"Logout","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"refresh_token\":\"{{refreshToken}}\"}"},"url":"{{baseUrl}}/auth/logout"}},
      {"name":"Current user","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/auth/me"}},
      {"name":"Get profile","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/users/{{userId}}"}},
      {"name":"Update profile","request":{"method":"PATCH","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"first_name\":\"Ivan\",\"last_name\":\"Sidorov\"}"},"url":"{{baseUrl}}/users/{{userId}}"}}
    ]},
    {"name":"03 Public catalog","item":[
      {"name":"List games","request":{"method":"GET","url":"{{baseUrl}}/games?page=1&page_size=20&search="}},
      {"name":"Get game","request":{"method":"GET","url":"{{baseUrl}}/games/{{gameId}}"}},
      {"name":"List accounts","request":{"method":"GET","url":"{{baseUrl}}/accounts?page=1&page_size=20&status=Available"}},
      {"name":"Get account","request":{"method":"GET","url":"{{baseUrl}}/accounts/{{accountId}}"}},
      {"name":"Account availability","request":{"method":"GET","url":"{{baseUrl}}/accounts/{{accountId}}/availability"}},
      {"name":"List account reviews","request":{"method":"GET","url":"{{baseUrl}}/accounts/{{accountId}}/reviews"}}
    ]},
    {"name":"04 Renter, rental and payments","item":[
      {"name":"My balance","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/balance"}},
      {"name":"My ledger","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/ledger?page=1&page_size=20"}},
      {"name":"My refunds","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/refunds?page=1&page_size=20"}},
      {"name":"My rentals","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/rentals"}},
      {"name":"My rentals (legacy alias)","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/rentals"}},
      {"name":"My payments","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/payments"}},
      {"name":"My payments (legacy alias)","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/payments"}},
      {"name":"Create payment record","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"rental_id\":{{rentalId}}}"},"url":"{{baseUrl}}/payments"}},
      {"name":"Get payment","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/payments/{{paymentId}}"}},
      {"name":"Cancel WAITING_PAYMENT rental","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/rentals/{{rentalId}}/cancel"}},
      {"name":"Extension intentionally unsupported (501)","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"duration_hours\":2}"},"url":"{{baseUrl}}/rentals/{{rentalId}}/extend"}},
      {"name":"Create review","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"account_id\":{{accountId}},\"rental_id\":{{rentalId}},\"rating\":5,\"comment\":\"Postman test review\"}"},"url":"{{baseUrl}}/reviews"}},
      {"name":"List notifications (canonical)","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/me/notifications"}},
      {"name":"List notifications (legacy alias)","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/notifications"}},
      {"name":"Mark notification read","request":{"method":"PATCH","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/notifications/{{notificationId}}/read"}},
      {"name":"Add favorite (MVP no persistence)","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/accounts/{{accountId}}/favorite"}},
      {"name":"Remove favorite (MVP no persistence)","request":{"method":"DELETE","header":[{"key":"Authorization","value":"Bearer {{accessToken}}"}],"url":"{{baseUrl}}/accounts/{{accountId}}/favorite"}}
    ]},
    {"name":"05 Provider payment webhook","item":[
      {"name":"Successful webhook (HMAC-SHA256)","event":[{"listen":"prerequest","script":{"exec":["const payload=JSON.stringify({payment_id:String(pm.collectionVariables.get('paymentId')),rental_id:String(pm.collectionVariables.get('rentalId')),external_transaction_id:pm.collectionVariables.replaceIn('{{externalTransactionId}}'),provider:'internal',amount:Number(pm.collectionVariables.get('pricePerHour'))*Number(pm.collectionVariables.get('durationHours'))+Number(pm.collectionVariables.get('securityDeposit')),currency:'USD',status:'success'}); pm.collectionVariables.set('webhookPayload',payload); pm.collectionVariables.set('paymentSignature',CryptoJS.HmacSHA256(payload,pm.collectionVariables.get('paymentWebhookSecret')).toString(CryptoJS.enc.Hex));"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"X-Payment-Signature","value":"{{paymentSignature}}"}],"body":{"mode":"raw","raw":"{{webhookPayload}}"},"url":"{{baseUrl}}/payments/webhook"}},
      {"name":"Replay webhook idempotently","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"X-Payment-Signature","value":"{{paymentSignature}}"}],"body":{"mode":"raw","raw":"{{webhookPayload}}"},"url":"{{baseUrl}}/payments/webhook"}}
    ]},
    {"name":"06 Administration","item":[
      {"name":"List accounts","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/accounts"}},
      {"name":"Update account pricing","request":{"method":"PATCH","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"price_per_hour\":{{pricePerHour}},\"security_deposit\":{{securityDeposit}}}"},"url":"{{baseUrl}}/admin/accounts/{{accountId}}"}},
      {"name":"Sync Steam library","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/accounts/{{accountId}}/sync"}},
      {"name":"List users","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/users"}},
      {"name":"Update user role/trust/block","request":{"method":"PATCH","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"trust_score\":100}"},"url":"{{baseUrl}}/admin/users/{{userId}}"}},
      {"name":"List rentals with filters","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/rentals?page=1&page_size=20&rental_status=&payment_status=&payment_provider=&deposit_status=&refund_status=&eligible_wallet_refund=&user_id=&rental_id="}},
      {"name":"Admin rental detail","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/rentals/{{rentalId}}"}},
      {"name":"Wallet refund reason codes","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/refund-reason-codes"}},
      {"name":"Wallet refund after expiry","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"reason_code\":\"ADMIN_CORRECTION\"}"},"url":"{{baseUrl}}/admin/rentals/{{rentalId}}/wallet-refund"}},
      {"name":"Forfeit deposit after expiry","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"reason_code\":\"DAMAGE_CONFIRMED\",\"evidence_reference\":\"SECURITY_EVENT:1\"}"},"url":"{{baseUrl}}/admin/rentals/{{rentalId}}/deposit/forfeit"}},
      {"name":"Audit logs","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{adminAccessToken}}"}],"url":"{{baseUrl}}/admin/audit-logs"}}
    ]}
  ]
}
