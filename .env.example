HTTP_ADDR=0.0.0.0:8080
HTTP_SHUTDOWN_TIMEOUT=15s

ENCRYPTION_KEY=your-32-byte-aes-encryption-key-here
JWT_SECRET=your-jwt-token-signing-secret-key-here
JWT_TTL=15m

LOGGER_LEVEL=INFO
LOGGER_FOLDER=out/logs

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=game_rental
POSTGRES_TIMEOUT=10s

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5433/game_rental
GOOSE_MIGRATION_DIR=./migrations

STEAM_API_KEY=
STEAM_BASE_URL=https://api.steampowered.com
# Required in every environment. Generate a unique random value of at least 32 bytes.
PAYMENT_WEBHOOK_SECRET=
